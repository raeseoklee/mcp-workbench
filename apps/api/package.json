{
  "name": "@mcp-lab/api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "MCP Lab API server — HTTP bridge between the web UI and MCP packages",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mcp-lab/session-engine": "workspace:*",
    "@mcp-lab/transport-stdio": "workspace:*",
    "@mcp-lab/transport-http": "workspace:*",
    "@mcp-lab/test-spec": "workspace:*",
    "@mcp-lab/assertions": "workspace:*",
    "@mcp-lab/client-simulator": "workspace:*",
    "@mcp-lab/protocol-kernel": "workspace:*",
    "express": "^4.21.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/raeseoklee/mcp-lab.git"
  }
}
