{
  "name": "mcp-workbench",
  "version": "0.1.0",
  "description": "MCP Workbench — test, inspect, and validate MCP servers",
  "type": "module",
  "keywords": ["mcp", "model-context-protocol", "testing", "cli", "developer-tools"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/raeseoklee/mcp-workbench.git"
  },
  "homepage": "https://github.com/raeseoklee/mcp-workbench#readme",
  "bugs": {
    "url": "https://github.com/raeseoklee/mcp-workbench/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "mcp-workbench": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@mcp-workbench/protocol-kernel": "workspace:*",
    "@mcp-workbench/session-engine": "workspace:*",
    "@mcp-workbench/transport-stdio": "workspace:*",
    "@mcp-workbench/transport-http": "workspace:*",
    "@mcp-workbench/test-spec": "workspace:*",
    "@mcp-workbench/assertions": "workspace:*",
    "@mcp-workbench/client-simulator": "workspace:*",
    "@mcp-workbench/i18n": "workspace:*",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "@types/node": "^22.0.0"
  }
}
