{
  "name": "@mcp-workbench/plugin-junit",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "description": "MCP Workbench plugin — generates JUnit XML test report for CI systems",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mcp-workbench/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "@types/node": "^22.0.0"
  },
  "license": "Apache-2.0",
  "keywords": ["mcp", "model-context-protocol", "plugin", "reporter", "junit", "ci"],
  "repository": {
    "type": "git",
    "url": "https://github.com/raeseoklee/mcp-workbench.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": ["dist"]
}
