{
  "name": "@mcp-workbench/i18n",
  "version": "0.1.0",
  "type": "module",
  "description": "Lightweight i18n for MCP Workbench — works in both Node.js and browser",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "locales"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "license": "Apache-2.0",
  "keywords": ["mcp", "i18n", "internationalization"],
  "repository": {
    "type": "git",
    "url": "https://github.com/raeseoklee/mcp-workbench.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "@types/node": "^22.0.0"
  }
}
