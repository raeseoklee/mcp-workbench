{
  "name": "@mcp-workbench/spec-generator",
  "version": "0.1.0",
  "private": true,
  "description": "Auto-generate YAML test specs from MCP server discovery",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mcp-workbench/protocol-kernel": "workspace:*",
    "@mcp-workbench/session-engine": "workspace:*",
    "@mcp-workbench/transport-stdio": "workspace:*",
    "@mcp-workbench/transport-http": "workspace:*",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "@types/node": "^22.0.0"
  }
}
